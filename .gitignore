# Local parquet snapshots (default data path is S3; optional offline seed)
dashboard/data/positions_0.parquet
dashboard/data/positions_0_*.parquet
dashboard/data/**/*_backup*.parquet

# Packaged GTFS zip duplicates (extracted folders are canonical)
dashboard/data/gtfs-sched.zip

# Local SQLite dev DB
dashboard/db/*.db
dashboard/db/*.db-*

# macOS junk inside GTFS trees
**/__MACOSX/
**/._*

